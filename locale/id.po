#: libraries/lib-import-export/Import.cpp
#, c-format
msgid ""
"\"%s\" is a playlist file. \n"
"Tenacity cannot open this file because it only contains links to other "
"files. \n"
"You may be able to open it in a text editor and download the actual audio "
"files."
msgstr ""
"\"%s\" adalah file daftar putar. \n"
"Tenacity tidak dapat membuka file ini karena hanya berisi tautan ke file "
"lain. \n"
"Anda mungkin dapat membukanya di editor teks dan mengunduh file audio yang "
"sebenarnya."

#. i18n-hint: %s will be the filename
#: libraries/lib-import-export/Import.cpp
#, c-format
msgid ""
"\"%s\" is a Windows Media Audio file. \n"
"Tenacity cannot open this type of file due to patent restrictions. \n"
"You need to convert it to a supported audio format, such as WAV or AIFF."
msgstr ""
"\"%s\" adalah file Windows Media Audio. \n"
"Tenacity tidak dapat membuka jenis file ini karena pembatasan paten. \n"
"Anda perlu mengonversinya ke format audio yang didukung, seperti WAV atau "
"AIFF."

#. i18n-hint: %s will be the filename
#: libraries/lib-import-export/Import.cpp
#, c-format
msgid ""
"\"%s\" is an Advanced Audio Coding file.\n"
"Without the optional FFmpeg library, Tenacity cannot open this type of "
"file.\n"
"Otherwise, you need to convert it to a supported audio format, such as WAV "
"or AIFF."
msgstr ""
"\"%s\" adalah file Advanced Audio Coding.\n"
"Tanpa pustaka FFmpeg opsional, Tenacity tidak dapat membuka jenis file ini.\n"
"Jika tidak, Anda perlu mengonversinya ke format audio yang didukung, seperti "
"WAV atau AIFF."

#. i18n-hint: %s will be the filename
#: libraries/lib-import-export/Import.cpp
#, c-format
msgid ""
"\"%s\" is an encrypted audio file. \n"
"These typically are from an online music store. \n"
"Tenacity cannot open this type of file due to the encryption. \n"
"Try recording the file into Tenacity, or burn it to audio CD then \n"
"extract the CD track to a supported audio format such as WAV or AIFF."
msgstr ""
"\"%s\" adalah file audio terenkripsi. \n"
"File seperti ini biasanya berasal dari toko musik daring. \n"
"Tenacity tidak dapat membuka jenis file ini karena enkripsinya. \n"
"Coba rekam file ini ke dalam Audacity, atau bakar ke CD audio lalu \n"
"ekstrak trek CD ke format audio yang didukung seperti WAV atau AIFF."

#. i18n-hint: %s will be the filename
#: libraries/lib-import-export/Import.cpp
#, c-format
msgid ""
"\"%s\" is a RealPlayer media file. \n"
"Tenacity cannot open this proprietary format. \n"
"You need to convert it to a supported audio format, such as WAV or AIFF."
msgstr ""
"\"%s\" adalah file media RealPlayer. \n"
"Tenacity tidak dapat membuka format proprietari ini. \n"
"Anda perlu mengonversinya ke format audio yang didukung, seperti WAV atau "
"AIFF."

#. i18n-hint: %s will be the filename
#: libraries/lib-import-export/Import.cpp
#, c-format
msgid ""
"\"%s\" is a notes-based file, not an audio file. \n"
"Tenacity cannot open this type of file. \n"
"Try converting it to an audio file such as WAV or AIFF and \n"
"then import it, or record it into Tenacity."
msgstr ""
"\"%s\" adalah file berbasis not, bukan file audio. \n"
"Tenacity tidak dapat membuka jenis file ini. \n"
"Coba konversikan ke file audio seperti WAV atau AIFF lalu \n"
"impor, atau rekam ke dalam Audacity."

#. i18n-hint: %s will be the filename
#: libraries/lib-import-export/Import.cpp
#, c-format
msgid ""
"\"%s\" is a Musepack audio file. \n"
"Tenacity cannot open this type of file. \n"
"If you think it might be an mp3 file, rename it to end with \".mp3\" \n"
"and try importing it again. Otherwise you need to convert it to a supported "
"audio \n"
"format, such as WAV or AIFF."
msgstr ""
